# MongoDB Compass connection
# No-auth local default:
# MONGODB_URI=mongodb://127.0.0.1:27017
# Auth-enabled example:
# MONGODB_URI=mongodb://<username>:<password>@127.0.0.1:27017/?authSource=admin
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB=watch_spy_agent

# Optional AI mode
AI_ENABLED=false
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# Runtime mode
NODE_ENV=development

# Forgot password mail settings (Gmail SMTP recommended)
APP_BASE_URL=http://localhost:3000
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_FROM=your_email@gmail.com
RESET_TOKEN_TTL_MINUTES=15
EXPOSE_DEV_RESET_LINK=true

# App settings
PORT=5000